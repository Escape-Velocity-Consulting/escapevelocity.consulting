<script>
// Legacy shared-result URL handler: /quiz/?r=XXXXX → redirect to /quiz/check/?s=XXXXX
// Runs inline in head before any content renders to avoid landing flash for shared links.
(function () {
  var r = new URLSearchParams(window.location.search).get('r');
  if (r && /^\d{5}$/.test(r)) {
    window.location.replace('/quiz/check/?s=' + r);
  }
})();
</script>


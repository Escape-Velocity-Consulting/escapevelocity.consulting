            <circle cx="223.51" cy="192.36" r="6" fill="var(--color-terracotta)"/>
            <circle cx="152.98" cy="224.72" r="6" fill="var(--color-terracotta)"/>
            <circle cx="123.92" cy="135.28" r="6" fill="var(--color-terracotta)"/>
            {# Labels #}
            <text x="200" y="26" text-anchor="middle" class="radar-label" font-weight="600">Prozesse</text>
            <text x="328.13" y="122.92" text-anchor="start" class="radar-label" font-weight="600">Tools</text>
            <text x="280.53" y="271.08" text-anchor="start" class="radar-label" font-weight="600">Daten</text>
            <text x="119.47" y="271.08" text-anchor="end" class="radar-label" font-weight="600">Team</text>
            <text x="71.87" y="122.92" text-anchor="end" class="radar-label" font-weight="600">Führung</text>
          </svg>
        </div>
        <div class="radar-benefits">
          <div class="benefit-item">
            <div class="benefit-check"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>
            <div class="benefit-text">
              <h4>Digitalisierungs-Level auf einen Blick</h4>
              <p>Über 5 Dimensionen ausgewertet: Prozesse, Tools, Daten, Team und Führung.</p>
            </div>
          </div>
          <div class="benefit-item">
            <div class="benefit-check"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>
            <div class="benefit-text">
              <h4>Der Engpass, konkret benannt</h4>
              <p>Nicht geraten, sondern aus Ihren Antworten abgeleitet.</p>
            </div>
          </div>
          <div class="benefit-item">
            <div class="benefit-check"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>
            <div class="benefit-text">
              <h4>Ein nächster Schritt, der passt</h4>
              <p>Zu Ihrer Situation, nicht von der Stange.</p>
            </div>
          </div>
        </div>
      </div>
      <div style="text-align:center">
        <button class="btn-primary btn-large landing-cta">Jetzt Digital-Check starten <span class="btn-arrow">&rarr;</span></button>
      </div>
    </div>


<!-- Newsletter form submission to HubSpot Forms API -->
<script>
  document.querySelectorAll('.ev-newsletter-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = form.querySelector('input[type="email"]').value;
      var checkbox = form.querySelector('input[type="checkbox"]');
      var btn = form.querySelector('button[type="submit"]');
      var msg = form.querySelector('.ev-form-message');

      if (!checkbox.checked) return;

      btn.disabled = true;
      btn.textContent = '...';

      fetch('https://api-eu1.hsforms.com/submissions/v3/integration/submit/147929039/1fe34adb-27cb-4088-9146-fe05be888cb5', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fields: [{ name: 'email', value: email }],
          context: { pageUri: window.location.href, pageName: document.title },
          legalConsentOptions: {
            consent: {
              consentToProcess: true,
              text: 'Ich möchte den Escape Velocity Newsletter erhalten und stimme zu, dass meine E-Mail-Adresse zu diesem Zweck verarbeitet wird. Abmeldung jederzeit möglich.',
              communications: [{
                value: true,
                subscriptionTypeId: 999,
                text: 'Escape Velocity Newsletter'
              }]
            }
          }
        })
      })
      .then(function(res) {
        if (res.ok) {
          msg.style.display = 'block';
          msg.className = 'ev-form-message ev-form-success';
          msg.textContent = 'Willkommen an Bord! Bestätigen Sie bitte Ihre E-Mail.';
          form.querySelector('input[type="email"]').value = '';
          checkbox.checked = false;
          btn.disabled = false;
          btn.textContent = form.dataset.form === 'hero' ? 'Anmelden' : 'Anmelden →';
        } else {
          throw new Error('Submission failed');
        }
      })
      .catch(function() {
        msg.style.display = 'block';
        msg.className = 'ev-form-message ev-form-error';
        msg.textContent = 'Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut.';
        btn.disabled = false;
        btn.textContent = form.dataset.form === 'hero' ? 'Anmelden' : 'Anmelden →';
      });
    });
  });
</script>

<!-- Scroll-triggered animations -->
<script>
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        if (entry.target.id === 'transitionText') {
          var chaos = document.getElementById('toolChaos');
          if (chaos && !chaos.classList.contains('scattered')) {
            setTimeout(function() { chaos.classList.add('scattered'); }, 1200);
          }
        }
      }
    });
  }, { threshold: 0.5 });

  var tt = document.getElementById('transitionText');
  if (tt) observer.observe(tt);
</script>


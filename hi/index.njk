<style>
  body {
    background: var(--color-black);
    color: var(--color-light);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .card {
    width: 100%;
    max-width: 420px;
    padding: 24px 28px 32px;
    text-align: center;
  }

  /* Brand */
  .card-brand {
    font-family: var(--font-headline);
    font-size: 26px;
    font-weight: 700;
    color: var(--color-light);
    letter-spacing: -0.3px;
    margin-bottom: 4px;
  }
  .card-brand .accent { color: var(--color-accent); }
  .card-claim {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 32px;
  }
  .card-tags {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    margin-bottom: 32px;
  }
  .card-tags .dot {
    margin: 0 8px;
    color: var(--color-subtle);
  }

  /* Identity */
  .card-name {
    font-family: var(--font-headline);
    font-size: 32px;
    font-weight: 700;
    color: var(--color-light);
    margin-bottom: 6px;
  }
  .card-role {
    font-family: var(--font-headline);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  /* Contact rows */
  .card-contact {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }
  .card-contact a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: var(--color-light);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 13px;
    transition: background 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .card-contact a span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-contact a:hover {
    background: rgba(255,255,255,0.1);
  }
  .card-contact .icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    opacity: 0.6;
  }

  /* Primary CTA */
  .card-cta {
    display: block;
    width: 100%;
    padding: 16px;
    background: var(--color-terracotta);
    color: #fff;
    border-radius: 10px;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    text-align: center;
    margin-bottom: 16px;
    transition: background 0.15s;
  }
  .card-cta:hover {
    background: var(--color-terracotta-hover);
  }

  /* Secondary links */
  .card-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 40px;
  }
  .card-links a {
    display: block;
    padding: 13px 16px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    color: var(--color-light);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 14px;
    text-decoration: none;
    text-align: center;
    transition: background 0.15s, border-color 0.15s;
  }
  .card-links a:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.2);
  }

  /* Footer */
  .card-footer {
    font-size: 12px;
    color: var(--color-subtle);
    display: flex;
    justify-content: center;
    gap: 16px;
  }
  .card-footer a {
    color: var(--color-subtle);
    text-decoration: none;
  }
  .card-footer a:hover {
    color: var(--color-muted);
  }
</style>
</head>

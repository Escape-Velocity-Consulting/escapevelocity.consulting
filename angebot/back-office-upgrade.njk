  .invest-note { font-size: 15px; color: var(--color-body); line-height: 1.6; margin-bottom: 28px; }

  /* Calculator */
  .calc-dynamic { margin-top: 32px; }
  .calc-dynamic h3 {
    font-family: var(--font-headline); font-size: 18px; font-weight: 600;
    color: var(--color-text); margin-bottom: 16px;
  }
  .calc-inputs { display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
  .calc-field { flex: 1; min-width: 200px; }
  .calc-field label {
    display: block; font-size: 13px; color: var(--color-subtle);
    margin-bottom: 6px; font-family: var(--font-ui); font-weight: 500;
  }
  .calc-field input {
    width: 100%; padding: 12px 16px; border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.1); background: var(--color-cream);
    font-size: 16px; font-family: var(--font-body); color: var(--color-text);
  }
  .calc-field input:focus { outline: none; border-color: var(--color-terracotta); }
  .calc-results {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
  }
  .calc-result-card {
    background: var(--color-cream); border-radius: 8px; padding: 16px;
  }
  .calc-result-card .value {
    font-family: var(--font-headline); font-size: 22px; font-weight: 700;
    color: var(--color-terracotta);
  }
  .calc-result-card .desc {

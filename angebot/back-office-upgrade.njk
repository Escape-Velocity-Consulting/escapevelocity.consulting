<script>
(function() {
  var hoursEl = document.getElementById('calc-hours');
  var rateEl = document.getElementById('calc-rate');
  var fmt = new Intl.NumberFormat('de-AT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });

  function update() {
    var h = parseFloat(hoursEl.value) || 0;
    var r = parseFloat(rateEl.value) || 0;
    var weekly = h * r;
    var monthly = Math.round(weekly * 4.33);
    var annual = weekly * 52;
    var months = annual > 0 ? Math.ceil((7500 / annual) * 12) : 0;

    document.getElementById('calc-weekly').textContent = fmt.format(weekly);
    document.getElementById('calc-monthly').textContent = fmt.format(monthly);
    document.getElementById('calc-annual').textContent = fmt.format(annual);
    document.getElementById('calc-roi').textContent = months > 0 ? 'ca. ' + months + ' Monate' : '—';
  }

  hoursEl.addEventListener('input', update);
  rateEl.addEventListener('input', update);
  update();
})();
</script>
